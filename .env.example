# ============================================================
# IGA Scheduler — environment variable reference
# Copy to .env and fill in values. Never commit .env.
#
# MODE: set APP_MODE=local or APP_MODE=production (default: production)
# Local mode uses SQLite + local filesystem; all GCP/ES vars below
# are ONLY required in production mode.
# ============================================================

APP_MODE=local

# ─── Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # set to "production" on Cloud Run

# ─── Public API auth (PingOne) ── required in ALL modes ──────
PUBLIC_API_ISSUER=https://auth.pingone.com/<env-id>/as
PUBLIC_API_AUDIENCE=https://iga-scheduler.example.com
# Optional: restrict to a specific PingOne scope
# PUBLIC_API_REQUIRED_SCOPE=scheduler:manage
# Optional: override JWKS URL if not <issuer>/.well-known/jwks.json
# PUBLIC_API_JWKS_URL=https://auth.pingone.com/<env-id>/as/jwks

# ─── Internal OIDC auth (Google) ── required in ALL modes ────
# Audience accepted for /internal/worker/* calls
WORKER_OIDC_AUDIENCE=https://iga-scheduler.example.com
# Service account email allowed to invoke /internal/worker/*
WORKER_INVOKER_SERVICE_ACCOUNT_EMAIL=iga-worker@<project>.iam.gserviceaccount.com
# Audience accepted for /internal/scheduler/* calls
SCHEDULER_OIDC_AUDIENCE=https://iga-scheduler.example.com
# Service account email allowed to invoke /internal/scheduler/*
SCHEDULER_INVOKER_SERVICE_ACCOUNT_EMAIL=iga-scheduler-tick@<project>.iam.gserviceaccount.com

# ─── Dispatch poller ─────────────────────────────────────────
DISPATCH_POLL_INTERVAL_MS=5000
DISPATCH_POLL_BATCH_SIZE=10

# ====================================================================
# LOCAL MODE ONLY (APP_MODE=local)
# ====================================================================

# Directory for SQLite DB and artifact zips (default: .local-data)
LOCAL_DATA_DIR=.local-data

# Sensitive parameter values injected by name: LOCAL_SECRET_<PARAM_NAME_UPPER>
# Example: if a job parameter is named "api_key", set LOCAL_SECRET_API_KEY=...
# LOCAL_SECRET_API_KEY=my-dev-secret

# ====================================================================
# PRODUCTION MODE ONLY (APP_MODE=production)
# ====================================================================

# ─── GCP project ─────────────────────────────────────────────
GCP_PROJECT_ID=my-gcp-project

# ─── GCS — job artifact storage ──────────────────────────────
JOB_ZIP_BUCKET=my-job-zip-bucket

# ─── Postgres (Cloud SQL) ────────────────────────────────────
# Use DB_ENGINE=cloud-sql for Cloud SQL connector (recommended in production)
# Use DB_ENGINE=direct + DATABASE_URL for AlloyDB Auth Proxy or local PG
DB_ENGINE=cloud-sql
DB_INSTANCE_CONNECTION_NAME=<project>:<region>:<instance>
DB_NAME=iga_scheduler
DB_USER=iga_scheduler_app
# DB_PASSWORD=                    # leave blank for IAM auth
# DB_IP_TYPE=PRIVATE              # PRIVATE (default) or PUBLIC

# For DB_ENGINE=direct (AlloyDB Auth Proxy sidecar or local Postgres):
# DATABASE_URL=postgresql://iga_scheduler_app@localhost:5432/iga_scheduler
# DB_ALLOW_DIRECT=true            # required safety flag for direct mode in production

# ─── Elasticsearch ───────────────────────────────────────────
ES_ENDPOINT=https://my-cluster.es.io:9243
ES_API_KEY=<base64-encoded-api-key>
# ES_DEFINITIONS_INDEX=scheduler_definitions_v1   # override index name
# ES_AUDIT_INDEX=scheduler_audit_v1               # override index name

# ─── Worker execution ────────────────────────────────────────
WORKER_EXECUTION_MODE=isolated    # "isolated" required in production

# ─── Cloud Run job runtime ───────────────────────────────────
RUNTIME_CLOUD_RUN_JOB_NAME=iga-job-runtime
RUNTIME_SERVICE_ACCOUNT_EMAIL=iga-runtime@<project>.iam.gserviceaccount.com
RUNTIME_BROKER_URL=https://iga-scheduler.example.com

# ─── IGA API ─────────────────────────────────────────────────
IGA_TOKEN_ENDPOINT=https://iga.example.com/oauth/token
IGA_CLIENT_ID=<client-id>
IGA_CLIENT_SECRET=<client-secret>
IGA_BASE_URL=https://iga.example.com
