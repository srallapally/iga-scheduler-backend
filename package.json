{
  "name": "iga-scheduler",
  "version": "1.0.0",
  "description": "IGA Scheduler Wrapper SDK",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "start": "node src/main.js",
    "start:local": "APP_MODE=local node --env-file-if-exists .env.local src/main.js",
    "start:prod": "APP_MODE=production node src/main.js",
    "dev": "node src/main.js",
    "test": "vitest run",
    "bootstrap": "APP_MODE=local node --env-file-if-exists .env.local scripts/bootstrap.js",
    "bootstrap:prod": "node scripts/prod/bootstrap-prod.js",
    "bootstrap:prod:dry-run": "node scripts/prod/bootstrap-prod.js --dry-run",
    "preflight": "node --env-file-if-exists .env.local scripts/prod/preflight.js",
    "teardown:prod": "node scripts/prod/teardown.js",
    "teardown:prod:dry-run": "node scripts/prod/teardown.js --dry-run",
    "bootstrap:es": "node scripts/bootstrap-es-indices.js",
    "migrate:up": "node-pg-migrate up --migrations-dir migrations",
    "migrate:down": "node-pg-migrate down --migrations-dir migrations"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.4.2",
    "@google-cloud/cloud-sql-connector": "^1.4.0",
    "@google-cloud/secret-manager": "^6.1.0",
    "@google-cloud/storage": "^7.19.0",
    "cron-parser": "^5.5.0",
    "express": "^5.2.1",
    "google-auth-library": "^10.5.0",
    "jose": "^5.10.0",
    "multer": "^2.1.1",
    "node-pg-migrate": "^7.9.1",
    "pg": "^8.16.0",
    "uuid": "^14.0.0",
    "yauzl": "^3.3.2",
    "zod": "^4.4.3"
  }
}
